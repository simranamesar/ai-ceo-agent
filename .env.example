# ---- LLM endpoint / model (open models only) ----
# Option A - in-process transformers on a GPU:
#   export LLM_PROVIDER=local
#   export LLM_MODEL=Qwen/Qwen3-8B
# Option B - an OpenAI-compatible endpoint (Ollama / vLLM):
LLM_PROVIDER=ollama
LLM_BASE_URL=http://localhost:11434/v1
LLM_API_KEY=local
LLM_MODEL=qwen3:8b
