# ---- LLM endpoint / model (open models only) ----
# Copy this file to .env and fill in your values. .env is gitignored.

# Option A - Groq free API (recommended for local testing, sign up at console.groq.com):
LLM_PROVIDER=ollama
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=gsk_your_groq_key_here
LLM_MODEL=qwen/qwen3.6-27b

# Option B - Ollama running locally:
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://localhost:11434/v1
# LLM_API_KEY=ollama
# LLM_MODEL=qwen3:8b

# Option C - vLLM on a remote server:
# LLM_PROVIDER=ollama
# LLM_BASE_URL=http://YOUR_SERVER_IP:8000/v1
# LLM_API_KEY=EMPTY
# LLM_MODEL=Qwen/Qwen3-8B
